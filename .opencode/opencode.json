{
  "$schema": "https://opencode.ai/config.json",
  "lsp": {
    "rust": {
      "command": ["rust-analyzer"],
      "extensions": [".rs"],
      "env": {
        "RA_LOG": "info"
      }
    },
    "typescript": {
      "command": ["typescript-language-server", "--stdio"],
      "extensions": [".ts", ".tsx", ".js", ".jsx", ".mjs", ".cjs", ".mts", ".cts"]
    },
    "kotlin-ls": {
      "command": ["kotlin-ls", "--stdio"],
      "extensions": [".kt", ".kts"]
    }
  }
}

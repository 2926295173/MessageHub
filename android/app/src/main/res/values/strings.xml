    <string name="about_title">About</string>
    <string name="about_version">Version %1$s</string>
    <string name="about_description">A LAN-first, self-hosted bridge to manage your Android phone from a desktop daemon. Notifications, SMS, and calls — all on your local network, no cloud.</string>
    <string name="about_license">License: GPL-3.0-or-later</string>
    <string name="about_protocol">Protocol: v1 (see docs/protocol-v1.md)</string>
    <string name="about_footer">No telemetry. No cloud. No account.</string>
    <string name="about_author_title">Author</string>
    <string name="about_author_body">PhoneBridge is developed and maintained by the PhoneBridge contributors. Source code, issues, and contribution guidelines live on GitHub.</string>
    <string name="about_repo_url">github.com/anomalyco/phonebridge</string>
    <string name="about_credits_title">Acknowledgments</string>
    <string name="about_credits_kde">KDE Connect — the open-source LAN phone-desktop bridge that inspired this project. The pairing code derivation (ECDH P-256 + HKDF-SHA256 short-code), the device-identity + cert-pinning model, and the overall protocol philosophy are all modeled after KDE Connect\'s well-vetted design. Thank you to the KDE community for years of pioneering work.</string>
    <string name="about_credits_kde_url">kdeconnect.kde.org</string>
    <string name="about_credits_other">Bouncy Castle, sqlx, Tokio, Axum, mDNSResponder, Next.js, Jetpack Compose — and the thousands of open-source contributors whose work makes this project possible.</string>

    <string name="about_title">关于</string>
    <string name="about_version">版本 %1$s</string>
    <string name="about_description">局域网优先、自托管的桥接工具，把 Android 手机交给桌面 message-center 管理。通知、短信、通话 — 全部在本地网络完成，不上云。</string>
    <string name="about_license">许可证：GPL-3.0-or-later</string>
    <string name="about_protocol">协议：v1（见 docs/protocol-v1.md）</string>
    <string name="about_footer">无遥测。无云端。无账户。</string>
    <string name="about_author_title">作者</string>
    <string name="about_author_body">PhoneBridge 由 PhoneBridge 贡献者开发与维护。源代码、Issue 提交与贡献指南托管在 GitHub。</string>
    <string name="about_repo_url">github.com/anomalyco/phonebridge</string>
    <string name="about_credits_title">鸣谢</string>
    <string name="about_credits_kde">KDE Connect — 启发本项目的开源局域网手机-桌面桥接方案。配对码派生（ECDH P-256 + HKDF-SHA256 短码）、设备身份 + 证书 pinning 模型、整套协议设计哲学都借鉴自 KDE Connect 经过多年验证的设计。感谢 KDE 社区的开创性贡献。</string>
    <string name="about_credits_kde_url">kdeconnect.kde.org</string>
    <string name="about_credits_other">Bouncy Castle、sqlx、Tokio、Axum、mDNSResponder、Next.js、Jetpack Compose —— 以及为这一切提供可能的所有开源贡献者。</string>
